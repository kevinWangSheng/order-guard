# OrderGuard 环境变量配置

# LLM 配置
OG_LLM_API_KEY=your-api-key-here
OG_LLM_API_BASE=https://api.openai.com/v1
OG_LLM_MODEL=openai/gpt-4o

# 飞书 Webhook（告警推送）
OG_FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/your-hook-id

# 飞书 Bot（对话模式）
FEISHU_APP_ID=your-feishu-app-id
FEISHU_APP_SECRET=your-feishu-app-secret
FEISHU_VERIFICATION_TOKEN=your-verification-token

# 数据库（默认 SQLite）
OG_DB_URL=sqlite:///data/orderguard.db

# 日志级别
OG_LOG_LEVEL=INFO
